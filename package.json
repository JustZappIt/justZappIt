{
  "name": "justzappit",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Zapp: an open-source, peer-to-peer encrypted messenger with a shielded Zcash wallet built in.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xVampirot/justZappIt.git"
  },
  "bugs": {
    "url": "https://github.com/0xVampirot/justZappIt/issues"
  },
  "homepage": "https://justzappit.xyz",
  "author": "justZappIt Contributors",
  "keywords": [
    "zcash",
    "encrypted-messenger",
    "shielded-wallet",
    "peer-to-peer",
    "web3"
  ],
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "test": "npm run test --workspace=apps/web",
    "type-check": "npx tsc --noEmit --project apps/web/tsconfig.json",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check ."
  },
  "devDependencies": {
    "supabase": "^2.84.4"
  }
}

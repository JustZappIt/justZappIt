# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── IP Hashing ─────────────────────────────────────────────────────────────
# Any random secret string, e.g. run: openssl rand -hex 32
IP_HASH_SALT=your_random_salt_here

# ─── hCaptcha ────────────────────────────────────────────────────────────────
# Register free at: https://hcaptcha.com
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_site_key_here
HCAPTCHA_SECRET_KEY=your_secret_key_here
# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://justzappit.xyz

# ─── Google (optional) ──────────────────────────────────────────────────────
# Google Search Console verification code (from GSC → Settings → Ownership)
# NEXT_PUBLIC_GSC_VERIFICATION=

# ─── Resend (Required for waitlist emails) ──────────────────────────────────────
# Sign up at https://resend.com — verify justzappit.xyz as a sending domain first
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=hello@justzappit.xyz

# ─── Contact Information ─────────────────────────────────────────────────────────
# General contact email
NEXT_PUBLIC_CONTACT_EMAIL=hello@justzappit.xyz
